MODELSCOPE_API_KEY=
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_CHAT_MODEL=Qwen/Qwen3.5-7B-Instruct

POSTGRES_URL=
REDIS_URL=
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
QDRANT_URL=
QDRANT_API_KEY=

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development

# AI 助手配置
# 可选值: modelscope, mock, openai, anthropic, local
NEXT_PUBLIC_AI_PROVIDER=modelscope

# ModelScope 配置（推荐）
MODELSCOPE_API_KEY=
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_CHAT_MODEL=Qwen/Qwen3.5-7B-Instruct

# 多模态模型（支持图片理解）
# MODELSCOPE_CHAT_MODEL=Qwen/Qwen3.5-VL-7B

# OpenAI 配置（如果使用 OpenAI）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Anthropic Claude 配置（如果使用 Claude）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# 本地模型配置（如果使用 Ollama）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
