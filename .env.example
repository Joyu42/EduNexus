# ModelScope API 配置
MODELSCOPE_API_KEY=your_modelscope_api_key_here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_CHAT_MODEL=Qwen/Qwen3.5-122B-A10B

# AI 提供商选择
NEXT_PUBLIC_AI_PROVIDER=modelscope

# NextAuth 认证配置
AUTH_SECRET=your-secret-key-here
AUTH_GITHUB_ID=your-github-app-id
AUTH_GITHUB_SECRET=your-github-app-secret

# 数据库配置（如果需要）
# DATABASE_URL=

# 其他配置
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js
AUTH_SECRET="your_strong_secret_here" # 运行 openssl rand -hex 32 生成
AUTH_URL="http://localhost:3000"

# GitHub Provider
AUTH_GITHUB_ID="your_github_client_id"
AUTH_GITHUB_SECRET="your_github_client_secret"
