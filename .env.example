# ===========================================
# EduNexus 环境变量配置
# ===========================================

# ===========================================
# 认证配置 (必需)
# ===========================================
# 运行以下命令生成密钥: npx auth secret
AUTH_SECRET=your-secret-key-here
AUTH_URL=http://localhost:3000

# ===========================================
# 数据库配置 (可选，默认使用JSON文件存储)
# ===========================================
# 如需使用 PostgreSQL，取消注释并配置连接字符串
# DATABASE_URL="postgresql://username:password@localhost:5432/edunexus"

# ===========================================
# AI 配置 (可选)
# ===========================================
# ModelScope API 配置
# MODELSCOPE_API_KEY=your_modelscope_api_key_here
# MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
# MODELSCOPE_CHAT_MODEL=Qwen/Qwen3.5-122B-A10B

# AI 提供商选择: modelscope | openai
# NEXT_PUBLIC_AI_PROVIDER=modelscope

# ===========================================
# 应用配置 (可选)
# ===========================================
# NEXT_PUBLIC_APP_URL=http://localhost:3000
